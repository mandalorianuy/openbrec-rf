{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/addons/drone-deployment-event/1.0.0",
  "title": "DroneDeploymentEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_type", "event_id", "timestamp", "deployment_id", "drone_id", "event_type", "release_mode", "flight_authority_in_core", "drop_sample_states_excluded_from_fusion", "limitations"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"enum": ["drone_deployment_event"]},
    "event_id": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "deployment_id": {"type": "string", "minLength": 1},
    "drone_id": {"type": "string", "minLength": 1},
    "payload_id": {"type": "string", "minLength": 1},
    "event_type": {"enum": ["drone_pose", "payload_armed", "payload_released", "drop_impact", "drop_stable", "node_online", "node_position_estimate", "drone_emi_baseline", "mission_aborted"]},
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lat", "lon"],
      "properties": {
        "lat": {"type": "number", "minimum": -90, "maximum": 90},
        "lon": {"type": "number", "minimum": -180, "maximum": 180},
        "alt_m": {"type": "number"},
        "accuracy_m": {"type": "number", "minimum": 0}
      }
    },
    "quality": {"type": "number", "minimum": 0, "maximum": 1},
    "motors_active": {"type": "boolean"},
    "release_mode": {"enum": ["human_confirmed", "human_confirmed_dual_operator"]},
    "flight_authority_in_core": {"const": false},
    "drop_sample_states_excluded_from_fusion": {"type": "array", "prefixItems": [{"const": "RELEASED"}, {"const": "IMPACT"}, {"const": "SETTLING"}], "minItems": 3, "maxItems": 3},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true}
  },
  "examples": [
    {"schema_version": "1.0.0", "record_type": "drone_deployment_event", "event_id": "evt-drop-001", "timestamp": "2026-07-17T18:00:00.000000Z", "deployment_id": "training-001", "drone_id": "uas-01", "event_type": "payload_released", "release_mode": "human_confirmed", "flight_authority_in_core": false, "drop_sample_states_excluded_from_fusion": ["RELEASED", "IMPACT", "SETTLING"], "limitations": ["autopilot keeps all flight authority", "telemetry and payload only"]},
    {"schema_version": "1.0.0", "record_type": "drone_deployment_event", "event_id": "evt-drop-002", "timestamp": "2026-07-17T18:05:00.000000Z", "deployment_id": "training-001", "drone_id": "uas-01", "payload_id": "drop-node-04", "event_type": "node_position_estimate", "position": {"lat": -34.3350641, "lon": -54.754415, "alt_m": 22.4, "accuracy_m": 1.5}, "quality": 0.92, "motors_active": true, "release_mode": "human_confirmed_dual_operator", "flight_authority_in_core": false, "drop_sample_states_excluded_from_fusion": ["RELEASED", "IMPACT", "SETTLING"], "limitations": ["estimate only, not a surveyed position", "autopilot keeps all flight authority", "release always human-confirmed"]}
  ]
}
