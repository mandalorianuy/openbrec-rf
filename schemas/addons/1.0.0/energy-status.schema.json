{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/addons/energy-status/1.0.0",
  "title": "EnergyStatus",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status_type", "energy_domain_id", "observed_at", "sequence", "fsm_state", "reason", "soc_status", "measurements", "loads_shed", "alarms", "sensors_absent", "limitations"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "status_type": {"enum": ["energy_status"]},
    "energy_domain_id": {"type": "string", "pattern": "^energy-[a-z0-9-]{3,48}$"},
    "observed_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "sequence": {"type": "integer", "minimum": 0},
    "fsm_state": {"enum": ["normal", "conserve", "critical", "survival", "shutdown", "unknown"]},
    "reason": {"type": "string", "minLength": 1},
    "soc_status": {"enum": ["measured", "estimated", "unknown"]},
    "runtime_lower_bound_s": {"type": "integer", "minimum": 0},
    "measurements": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["metric", "value", "unit", "uncertainty", "quality", "method"], "properties": {"metric": {"enum": ["voltage", "current", "power", "energy", "soc", "soh", "temperature"]}, "value": {"type": "number"}, "unit": {"enum": ["V", "A", "W", "W.h", "1", "Cel"]}, "uncertainty": {"type": "number", "minimum": 0}, "quality": {"type": "number", "minimum": 0, "maximum": 1}, "method": {"type": "string", "minLength": 1}}}},
    "loads_shed": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "alarms": {"type": "array", "items": {"enum": ["brownout", "over_voltage", "under_voltage", "over_temperature", "bms", "fuse", "sensor", "measurement_incoherent"]}, "uniqueItems": true},
    "sensors_absent": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true}
  },
  "examples": [
    {"schema_version": "1.0.0", "status_type": "energy_status", "energy_domain_id": "energy-cell-a", "observed_at": "2026-07-17T13:05:00.000000Z", "sequence": 1, "fsm_state": "unknown", "reason": "SOC sensor absent", "soc_status": "unknown", "measurements": [{"metric": "voltage", "value": 12.6, "unit": "V", "uncertainty": 0.1, "quality": 0.8, "method": "synthetic"}], "loads_shed": [], "alarms": ["sensor"], "sensors_absent": ["soc"], "limitations": ["no runtime claim"]},
    {"schema_version": "1.0.0", "status_type": "energy_status", "energy_domain_id": "energy-beacon-a", "observed_at": "2026-07-17T13:06:00.000000Z", "sequence": 2, "fsm_state": "conserve", "reason": "modeled reserve threshold", "soc_status": "estimated", "runtime_lower_bound_s": 14400, "measurements": [{"metric": "soc", "value": 0.4, "unit": "1", "uncertainty": 0.1, "quality": 0.6, "method": "modeled"}, {"metric": "power", "value": 2.1, "unit": "W", "uncertainty": 0.2, "quality": 0.7, "method": "synthetic"}], "loads_shed": ["thermal_high_rate"], "alarms": [], "sensors_absent": ["soh"], "limitations": ["simulation only"]}
  ]
}
