{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/addons/interop-emergency-standards-profile/1.0.0",
  "title": "InteropEmergencyStandardsProfile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_type", "profile_id", "created_at", "direction", "gateway_implemented", "source_message_types", "cap_mapping", "edxl_de_wrapper", "invariants", "limitations"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "profile_type": {"enum": ["interop_emergency_standards_profile"]},
    "profile_id": {"type": "string", "pattern": "^interop-[a-z0-9-]{3,64}$"},
    "created_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "direction": {"enum": ["export_only"]},
    "gateway_implemented": {"const": false},
    "source_message_types": {"type": "array", "items": {"enum": ["text", "status", "sos", "location"]}, "minItems": 1, "uniqueItems": true},
    "cap_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["standard", "field_map"],
      "properties": {
        "standard": {"const": "OASIS-CAP-1.2"},
        "field_map": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_field", "cap_element", "transform"],
            "properties": {
              "source_field": {"type": "string", "minLength": 1},
              "cap_element": {"enum": ["identifier", "sender", "sent", "status", "msgType", "scope", "info.category", "info.severity", "info.urgency", "info.certainty", "info.headline", "info.description", "area.areaDesc", "area.circle", "area.polygon"]},
              "transform": {"enum": ["copy", "iso8601_utc", "controlled_vocabulary", "incident_rotating_hash"]}
            }
          }
        }
      }
    },
    "edxl_de_wrapper": {
      "type": "object",
      "additionalProperties": false,
      "required": ["standard", "role", "distribution_type_declared_by"],
      "properties": {
        "standard": {"const": "EDXL-DE-1.0"},
        "role": {"const": "wrapper_only"},
        "distribution_type_declared_by": {"enum": ["exporting_operator", "receiving_agency"]}
      }
    },
    "invariants": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gateway_received_means_rescue", "cap_ack_means_operational_acceptance", "human_confirmation_required"],
      "properties": {
        "gateway_received_means_rescue": {"const": false},
        "cap_ack_means_operational_acceptance": {"const": false},
        "human_confirmation_required": {"const": true}
      }
    },
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true}
  },
  "examples": [
    {"schema_version": "1.0.0", "profile_type": "interop_emergency_standards_profile", "profile_id": "interop-sos-cap-export", "created_at": "2026-07-17T13:30:00.000000Z", "direction": "export_only", "gateway_implemented": false, "source_message_types": ["sos"], "cap_mapping": {"standard": "OASIS-CAP-1.2", "field_map": [{"source_field": "message_id", "cap_element": "identifier", "transform": "copy"}, {"source_field": "created_at", "cap_element": "sent", "transform": "iso8601_utc"}, {"source_field": "priority", "cap_element": "info.urgency", "transform": "controlled_vocabulary"}]}, "edxl_de_wrapper": {"standard": "EDXL-DE-1.0", "role": "wrapper_only", "distribution_type_declared_by": "exporting_operator"}, "invariants": {"gateway_received_means_rescue": false, "cap_ack_means_operational_acceptance": false, "human_confirmation_required": true}, "limitations": ["specified mapping only", "no gateway implemented", "export does not imply agency acceptance"]},
    {"schema_version": "1.0.0", "profile_type": "interop_emergency_standards_profile", "profile_id": "interop-full-edxl-export", "created_at": "2026-07-17T13:35:00.000000Z", "direction": "export_only", "gateway_implemented": false, "source_message_types": ["sos", "location", "status"], "cap_mapping": {"standard": "OASIS-CAP-1.2", "field_map": [{"source_field": "message_id", "cap_element": "identifier", "transform": "copy"}, {"source_field": "cell_id", "cap_element": "sender", "transform": "incident_rotating_hash"}, {"source_field": "created_at", "cap_element": "sent", "transform": "iso8601_utc"}, {"source_field": "message_type", "cap_element": "info.category", "transform": "controlled_vocabulary"}, {"source_field": "zone_id", "cap_element": "area.areaDesc", "transform": "copy"}, {"source_field": "payload_summary", "cap_element": "info.description", "transform": "copy"}]}, "edxl_de_wrapper": {"standard": "EDXL-DE-1.0", "role": "wrapper_only", "distribution_type_declared_by": "receiving_agency"}, "invariants": {"gateway_received_means_rescue": false, "cap_ack_means_operational_acceptance": false, "human_confirmation_required": true}, "limitations": ["specified mapping only", "no gateway implemented", "CAP Ack is transport receipt, not operational acceptance", "silence after export never means absence or rescue failure"]}
  ]
}
