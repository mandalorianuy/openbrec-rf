{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/addons/human-message/1.0.0",
  "title": "HumanMessage",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "message_type", "message_id", "incident_id", "cell_id", "actor_id", "device_id", "recipient", "priority", "created_at", "expires_at", "boot_id", "sequence", "signing_key_id", "encryption_key_id", "algorithm", "nonce", "ciphertext", "tag", "signature"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "message_type": {"enum": ["text", "status", "sos", "location"]},
    "message_id": {"type": "string", "format": "uuid"},
    "incident_id": {"type": "string", "format": "uuid"},
    "cell_id": {"type": "string", "pattern": "^cell-[a-z0-9-]{3,48}$"},
    "actor_id": {"type": "string", "pattern": "^actor-[0-9a-f]{16}$"},
    "device_id": {"type": "string", "pattern": "^device-[0-9a-f]{16}$"},
    "recipient": {"type": "string", "minLength": 1, "maxLength": 96},
    "priority": {"enum": ["routine", "urgent", "distress"]},
    "created_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "expires_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "boot_id": {"type": "string", "format": "uuid"},
    "sequence": {"type": "integer", "minimum": 0},
    "signing_key_id": {"type": "string", "minLength": 1},
    "encryption_key_id": {"type": "string", "minLength": 1},
    "algorithm": {"enum": ["AEAD_AES_256_GCM+Ed25519"]},
    "nonce": {"type": "string", "pattern": "^[A-Za-z0-9_-]{16}$"},
    "ciphertext": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$", "minLength": 1},
    "tag": {"type": "string", "pattern": "^[A-Za-z0-9_-]{22}$"},
    "signature": {"type": "string", "pattern": "^[A-Za-z0-9_-]{86}$"}
  },
  "examples": [
    {"schema_version": "1.0.0", "message_type": "sos", "message_id": "20000000-0000-4000-8000-000000000001", "incident_id": "11111111-1111-4111-8111-111111111111", "cell_id": "cell-alpha", "actor_id": "actor-1111111111111111", "device_id": "device-2222222222222222", "recipient": "role:rescue-command", "priority": "distress", "created_at": "2026-07-17T14:00:00.000000Z", "expires_at": "2026-07-17T14:15:00.000000Z", "boot_id": "33333333-3333-4333-8333-333333333333", "sequence": 1, "signing_key_id": "sign-cell-alpha-1", "encryption_key_id": "sos-cell-alpha-1", "algorithm": "AEAD_AES_256_GCM+Ed25519", "nonce": "AAAAAAAAAAAAAAAA", "ciphertext": "c29z", "tag": "AAAAAAAAAAAAAAAAAAAAAA", "signature": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"},
    {"schema_version": "1.0.0", "message_type": "text", "message_id": "20000000-0000-4000-8000-000000000002", "incident_id": "11111111-1111-4111-8111-111111111111", "cell_id": "cell-alpha", "actor_id": "actor-1111111111111111", "device_id": "device-2222222222222222", "recipient": "actor-3333333333333333", "priority": "routine", "created_at": "2026-07-17T14:01:00.000000Z", "expires_at": "2026-07-17T15:01:00.000000Z", "boot_id": "33333333-3333-4333-8333-333333333333", "sequence": 2, "signing_key_id": "sign-cell-alpha-1", "encryption_key_id": "direct-alpha-1", "algorithm": "AEAD_AES_256_GCM+Ed25519", "nonce": "BBBBBBBBBBBBBBBB", "ciphertext": "dGV4dA", "tag": "BBBBBBBBBBBBBBBBBBBBBB", "signature": "BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB"}
  ]
}
