{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/addons/transport-envelope/1.0.0",
  "title": "TransportEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "envelope_type", "envelope_id", "message_id", "bearer", "direction", "payload_schema_ref", "protected_payload_base64", "created_at", "expires_at", "hop_budget", "transport_metadata", "limitations"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "envelope_type": {"enum": ["openbrec_protected"]},
    "envelope_id": {"type": "string", "format": "uuid"},
    "message_id": {"type": "string", "format": "uuid"},
    "bearer": {"enum": ["meshtastic", "meshcore", "reticulum", "lorawan", "ip", "carry_bundle", "simulated"]},
    "direction": {"enum": ["outbound", "inbound"]},
    "payload_schema_ref": {"type": "string", "format": "uri"},
    "protected_payload_base64": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "expires_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "hop_budget": {"type": "integer", "minimum": 0, "maximum": 64},
    "transport_metadata": {"type": "object", "additionalProperties": false, "required": ["adapter", "adapter_version"], "properties": {"adapter": {"type": "string", "minLength": 1}, "adapter_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}, "path_id": {"type": "string", "maxLength": 96}}},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true}
  },
  "examples": [
    {"schema_version": "1.0.0", "envelope_type": "openbrec_protected", "envelope_id": "22000000-0000-4000-8000-000000000001", "message_id": "20000000-0000-4000-8000-000000000001", "bearer": "meshtastic", "direction": "outbound", "payload_schema_ref": "https://openbrec.org/schemas/addons/human-message/1.0.0", "protected_payload_base64": "cHJvdGVjdGVk", "created_at": "2026-07-17T14:00:00.000000Z", "expires_at": "2026-07-17T14:15:00.000000Z", "hop_budget": 3, "transport_metadata": {"adapter": "meshtastic-model", "adapter_version": "1.0.0"}, "limitations": ["transport is not identity"]},
    {"schema_version": "1.0.0", "envelope_type": "openbrec_protected", "envelope_id": "22000000-0000-4000-8000-000000000002", "message_id": "20000000-0000-4000-8000-000000000002", "bearer": "carry_bundle", "direction": "inbound", "payload_schema_ref": "https://openbrec.org/schemas/addons/human-message/1.0.0", "protected_payload_base64": "YnVuZGxl", "created_at": "2026-07-17T14:01:00.000000Z", "expires_at": "2026-07-18T14:01:00.000000Z", "hop_budget": 0, "transport_metadata": {"adapter": "signed-file", "adapter_version": "1.0.0", "path_id": "custody-a"}, "limitations": ["delayed delivery", "technical receipt only"]}
  ]
}
