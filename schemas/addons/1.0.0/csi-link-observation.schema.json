{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/addons/csi-link-observation/1.0.0",
  "title": "CsiLinkObservation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "observation_id", "sensor_id", "sensor_type", "observation_kind", "window_start", "window_end", "link", "amplitude_only", "baseline_ref", "max_declared_evidence", "measurements", "quality", "uncertainty", "coverage", "capabilities_absent", "silence_means_absence", "automatic_person_detection_allowed", "limitations"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "observation_id": {"type": "string", "format": "uuid"},
    "sensor_id": {"type": "string", "minLength": 1},
    "sensor_type": {"enum": ["addon_registered"]},
    "observation_kind": {"enum": ["measurement"]},
    "window_start": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "window_end": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "zone_id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{2,63}$"},
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tx_node_id", "rx_node_id", "channel", "bandwidth_mhz", "antenna_profile_id"],
      "properties": {
        "tx_node_id": {"type": "string", "minLength": 1},
        "rx_node_id": {"type": "string", "minLength": 1},
        "channel": {"type": "integer", "minimum": 1},
        "bandwidth_mhz": {"enum": [20, 40, 80]},
        "antenna_profile_id": {"type": "string", "pattern": "^antenna-[a-z0-9-]{3,48}$"}
      }
    },
    "amplitude_only": {"type": "boolean"},
    "baseline_ref": {"type": "string", "pattern": "^urn:sha256:[0-9a-f]{64}$"},
    "max_declared_evidence": {"const": "bench-validated"},
    "measurements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["measurement_type", "metric", "value", "unit", "uncertainty", "quality", "method"],
        "properties": {
          "measurement_type": {"enum": ["scalar"]},
          "metric": {"enum": ["csi.change_score", "csi.motion_index", "csi.breathing_candidate", "csi.unknown"]},
          "value": {"type": "number", "minimum": 0, "maximum": 1},
          "unit": {"enum": ["1"]},
          "uncertainty": {"type": "number", "minimum": 0},
          "quality": {"type": "number", "minimum": 0, "maximum": 1},
          "method": {"type": "string", "pattern": "^csi:[a-z0-9._-]+$"}
        }
      }
    },
    "quality": {"type": "number", "minimum": 0, "maximum": 1},
    "uncertainty": {"type": "number", "minimum": 0, "maximum": 1},
    "coverage": {"type": "string", "minLength": 1},
    "calibration_ref": {"type": "string", "pattern": "^urn:sha256:[0-9a-f]{64}$"},
    "capabilities_absent": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "silence_means_absence": {"const": false},
    "automatic_person_detection_allowed": {"const": false},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true}
  },
  "examples": [
    {"schema_version": "1.0.0", "observation_id": "32000000-0000-4000-8000-000000000001", "sensor_id": "csi-link-a1", "sensor_type": "addon_registered", "observation_kind": "measurement", "window_start": "2026-07-17T16:40:00.000000Z", "window_end": "2026-07-17T16:40:05.000000Z", "link": {"tx_node_id": "node-tx-01", "rx_node_id": "node-rx-01", "channel": 6, "bandwidth_mhz": 20, "antenna_profile_id": "antenna-esp32-stock"}, "amplitude_only": true, "baseline_ref": "urn:sha256:1111111111111111111111111111111111111111111111111111111111111111", "max_declared_evidence": "bench-validated", "measurements": [{"measurement_type": "scalar", "metric": "csi.change_score", "value": 0.35, "unit": "1", "uncertainty": 0.2, "quality": 0.6, "method": "csi:amplitude-variance-v1"}], "quality": 0.6, "uncertainty": 0.4, "coverage": "single synthetic csi window", "capabilities_absent": ["phase_sanitized_csi", "multi_link"], "silence_means_absence": false, "automatic_person_detection_allowed": false, "limitations": ["esp32 phase corrupted by cfo/sfo", "amplitude only", "no presence or absence inference"]},
    {"schema_version": "1.0.0", "observation_id": "32000000-0000-4000-8000-000000000002", "sensor_id": "csi-link-b2", "sensor_type": "addon_registered", "observation_kind": "measurement", "window_start": "2026-07-17T16:41:00.000000Z", "window_end": "2026-07-17T16:41:10.000000Z", "zone_id": "zone-a", "link": {"tx_node_id": "node-tx-02", "rx_node_id": "node-rx-02", "channel": 36, "bandwidth_mhz": 80, "antenna_profile_id": "antenna-nexmon-rpi"}, "amplitude_only": false, "baseline_ref": "urn:sha256:2222222222222222222222222222222222222222222222222222222222222222", "max_declared_evidence": "bench-validated", "measurements": [{"measurement_type": "scalar", "metric": "csi.motion_index", "value": 0.7, "unit": "1", "uncertainty": 0.15, "quality": 0.7, "method": "csi:subcarrier-variance-v2"}, {"measurement_type": "scalar", "metric": "csi.breathing_candidate", "value": 0.4, "unit": "1", "uncertainty": 0.3, "quality": 0.5, "method": "csi:periodicity-v1"}], "quality": 0.65, "uncertainty": 0.35, "coverage": "modeled overlapping windows", "calibration_ref": "urn:sha256:3333333333333333333333333333333333333333333333333333333333333333", "capabilities_absent": ["through_wall_validation", "multi_person_counting"], "silence_means_absence": false, "automatic_person_detection_allowed": false, "limitations": ["candidate only, never automatic detection", "breathing candidate is bench-validated single-person LOS only", "silence never means absence"]}
  ]
}
