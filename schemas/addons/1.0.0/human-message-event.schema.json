{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/addons/human-message-event/1.0.0",
  "title": "HumanMessageEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "event_type", "event_id", "message_id", "occurred_at", "actor_type", "actor_id", "signature", "causation_event_ids", "limitations"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "event_type": {"enum": ["sos.created", "sos.queued", "transport.transmitted", "transport.relay_observed", "gateway.received", "operator.seen", "operator.accepted", "sos.cancel_requested", "sos.expired", "sos.failed"]},
    "event_id": {"type": "string", "format": "uuid"},
    "message_id": {"type": "string", "format": "uuid"},
    "occurred_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "actor_type": {"enum": ["terminal", "adapter", "gateway", "operator", "policy"]},
    "actor_id": {"type": "string", "minLength": 1},
    "signature": {"type": "string", "pattern": "^[A-Za-z0-9_-]{86}$"},
    "causation_event_ids": {"type": "array", "items": {"type": "string", "format": "uuid"}, "uniqueItems": true},
    "reason": {"type": "string", "minLength": 1},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true}
  },
  "examples": [
    {"schema_version": "1.0.0", "event_type": "sos.created", "event_id": "21000000-0000-4000-8000-000000000001", "message_id": "20000000-0000-4000-8000-000000000001", "occurred_at": "2026-07-17T14:00:00.000000Z", "actor_type": "terminal", "actor_id": "device-2222222222222222", "signature": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA", "causation_event_ids": [], "limitations": ["creation does not prove delivery"]},
    {"schema_version": "1.0.0", "event_type": "operator.accepted", "event_id": "21000000-0000-4000-8000-000000000002", "message_id": "20000000-0000-4000-8000-000000000001", "occurred_at": "2026-07-17T14:04:00.000000Z", "actor_type": "operator", "actor_id": "actor-4444444444444444", "signature": "BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB", "causation_event_ids": ["21000000-0000-4000-8000-000000000003", "21000000-0000-4000-8000-000000000004"], "reason": "operator assumed management", "limitations": ["acceptance does not guarantee rescue"]}
  ]
}
