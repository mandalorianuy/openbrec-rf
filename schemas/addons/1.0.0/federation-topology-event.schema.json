{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/addons/federation-topology-event/1.0.0",
  "title": "FederationTopologyEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "topology_event_type", "event_id", "topology_version", "effective_at", "entity_id", "entity_type", "status", "valid_from", "valid_until", "public_identity_ref", "capability_refs", "signature", "limitations"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "topology_event_type": {"enum": ["upsert", "status_changed", "closed"]},
    "event_id": {"type": "string", "format": "uuid"},
    "topology_version": {"type": "integer", "minimum": 1},
    "effective_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "entity_id": {"type": "string", "minLength": 1},
    "entity_type": {"enum": ["incident_federation", "operational_area", "response_cell", "deployment", "site"]},
    "parent_entity_id": {"type": "string", "minLength": 1},
    "cell_id": {"type": "string", "pattern": "^cell-[a-z0-9-]{3,48}$"},
    "status": {"enum": ["active", "isolated", "degraded", "closed", "unknown"]},
    "valid_from": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "valid_until": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "public_identity_ref": {"type": "string", "pattern": "^urn:sha256:[0-9a-f]{64}$"},
    "capability_refs": {"type": "array", "items": {"type": "string", "pattern": "^urn:sha256:[0-9a-f]{64}$"}, "uniqueItems": true},
    "previous_topology_event_id": {"type": "string", "format": "uuid"},
    "signature": {"type": "string", "pattern": "^[A-Za-z0-9_-]{86}$"},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true}
  },
  "examples": [
    {"schema_version": "1.0.0", "topology_event_type": "upsert", "event_id": "25000000-0000-4000-8000-000000000001", "topology_version": 1, "effective_at": "2026-07-17T15:00:00.000000Z", "entity_id": "area-north", "entity_type": "operational_area", "parent_entity_id": "incident-11111111", "status": "active", "valid_from": "2026-07-17T15:00:00.000000Z", "valid_until": "2026-07-18T15:00:00.000000Z", "public_identity_ref": "urn:sha256:1111111111111111111111111111111111111111111111111111111111111111", "capability_refs": [], "signature": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA", "limitations": ["simulation topology"]},
    {"schema_version": "1.0.0", "topology_event_type": "status_changed", "event_id": "25000000-0000-4000-8000-000000000002", "topology_version": 2, "effective_at": "2026-07-17T15:10:00.000000Z", "entity_id": "cell-alpha", "entity_type": "response_cell", "parent_entity_id": "area-north", "cell_id": "cell-alpha", "status": "isolated", "valid_from": "2026-07-17T15:10:00.000000Z", "valid_until": "2026-07-18T15:10:00.000000Z", "public_identity_ref": "urn:sha256:2222222222222222222222222222222222222222222222222222222222222222", "capability_refs": ["urn:sha256:3333333333333333333333333333333333333333333333333333333333333333"], "previous_topology_event_id": "25000000-0000-4000-8000-000000000003", "signature": "BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB", "limitations": ["isolation does not stop local operation"]}
  ]
}
