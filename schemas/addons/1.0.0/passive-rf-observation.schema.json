{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/addons/passive-rf-observation/1.0.0",
  "title": "PassiveRfObservation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_type", "observation_id", "observed_at", "sensor_id", "source", "subject_ref", "pseudonym_scheme", "band", "rssi_dbm", "rssi_uncertainty_db", "payload_retained", "content_interception", "active_emulation", "capabilities_absent", "limitations"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"enum": ["passive_rf_observation"]},
    "observation_id": {"type": "string", "format": "uuid"},
    "observed_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "sensor_id": {"type": "string", "minLength": 1},
    "source": {"enum": ["probe_request", "bt_advertisement", "rtl_433", "drone_id"]},
    "subject_ref": {"type": "string", "pattern": "^hmac-sha256:[0-9a-f]{64}$"},
    "pseudonym_scheme": {"const": "incident_rotating_hmac"},
    "band": {"enum": ["ism_2_4_ghz", "ism_5_ghz", "sub_ghz_ism", "uas_remote_id"]},
    "rssi_dbm": {"type": "number"},
    "rssi_uncertainty_db": {"type": "number", "minimum": 0},
    "zone_id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{2,63}$"},
    "isolation_profile_ref": {"type": "string", "pattern": "^urn:sha256:[0-9a-f]{64}$"},
    "payload_retained": {"const": false},
    "content_interception": {"const": false},
    "active_emulation": {"const": false},
    "capabilities_absent": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true}
  },
  "examples": [
    {"schema_version": "1.0.0", "record_type": "passive_rf_observation", "observation_id": "33000000-0000-4000-8000-000000000001", "observed_at": "2026-07-17T16:50:00.000000Z", "sensor_id": "kismet-node-01", "source": "probe_request", "subject_ref": "hmac-sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa", "pseudonym_scheme": "incident_rotating_hmac", "band": "ism_2_4_ghz", "rssi_dbm": -72.5, "rssi_uncertainty_db": 3, "payload_retained": false, "content_interception": false, "active_emulation": false, "capabilities_absent": ["payload_inspection"], "limitations": ["metadata only", "mac randomization degrades probes", "no presence or absence inference"]},
    {"schema_version": "1.0.0", "record_type": "passive_rf_observation", "observation_id": "33000000-0000-4000-8000-000000000002", "observed_at": "2026-07-17T16:51:00.000000Z", "sensor_id": "kismet-node-02", "source": "drone_id", "subject_ref": "hmac-sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb", "pseudonym_scheme": "incident_rotating_hmac", "band": "uas_remote_id", "rssi_dbm": -58, "rssi_uncertainty_db": 2.5, "zone_id": "zone-b", "isolation_profile_ref": "urn:sha256:4444444444444444444444444444444444444444444444444444444444444444", "payload_retained": false, "content_interception": false, "active_emulation": false, "capabilities_absent": [], "limitations": ["taken under announced rf-quieting window", "metadata only", "no persistent identifier stored"]}
  ]
}
