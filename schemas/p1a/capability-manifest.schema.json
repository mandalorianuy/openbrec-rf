{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/p1a/capability-manifest/1.0.0",
  "title": "P1a exact physical capability manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "asset_id",
    "candidate_id",
    "category",
    "manufacturer",
    "model",
    "sku",
    "hardware_revision",
    "serial_evidence_sha256",
    "custody",
    "physical_inspection",
    "capabilities",
    "support_status",
    "limitations"
  ],
  "properties": {
    "manifest_version": {"const": "1.0.0"},
    "asset_id": {"type": "string", "pattern": "^p1a-asset-[a-z0-9-]{4,64}$"},
    "candidate_id": {"type": "string", "pattern": "^P1A-HW-[0-9]{2}$"},
    "category": {
      "enum": [
        "lorawan_gateway",
        "lorawan_endpoint",
        "meshtastic_node",
        "meshcore_node",
        "rnode",
        "offline_terminal",
        "trimodal_beacon",
        "energy_storage",
        "wired_cell_gateway"
      ]
    },
    "manufacturer": {"type": "string", "minLength": 1},
    "model": {"type": "string", "minLength": 1},
    "sku": {"type": "string", "minLength": 1},
    "hardware_revision": {"type": "string", "minLength": 1},
    "serial_evidence_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "custody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "authorization_id", "custodian", "receipt_sha256"],
      "properties": {
        "method": {"enum": ["existing_asset", "loan", "purchase"]},
        "authorization_id": {"type": "string", "minLength": 1},
        "custodian": {"type": "string", "minLength": 1},
        "receipt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "physical_inspection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inspected_at", "inspector", "condition", "exact_match", "evidence_sha256"],
      "properties": {
        "inspected_at": {"type": "string", "format": "date-time"},
        "inspector": {"type": "string", "minLength": 1},
        "condition": {"enum": ["new", "serviceable", "damaged", "unknown"]},
        "exact_match": {"const": true},
        "evidence_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "firmware_pin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project", "version", "commit", "artifact_sha256", "advisory_reviewed_at"],
      "properties": {
        "project": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "artifact_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "advisory_reviewed_at": {"type": "string", "format": "date"}
      }
    },
    "support_status": {"enum": ["unverified"]},
    "limitations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
