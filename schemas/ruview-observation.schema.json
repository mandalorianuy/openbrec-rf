{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/ruview-observation/1.0.0",
  "title": "RuViewObservation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "timestamp",
    "node_id",
    "source_mode",
    "frame_format",
    "quality"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "node_id": {
      "type": "string"
    },
    "source_mode": {
      "enum": [
        "udp-adr018",
        "websocket",
        "file-replay",
        "python-sidecar"
      ]
    },
    "frame_format": {
      "type": "string"
    },
    "source_commit": {
      "type": "string"
    },
    "model_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "quality": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "features": {
      "type": "object"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
