{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/core/core-replay-receipt/1.0.0",
  "title": "CoreReplayReceipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "receipt_id", "generated_at", "result", "contract_set_sha256", "upstream_receipt_sha256", "engine_name", "engine_version", "engine_artifact_sha256", "configuration_sha256", "input_events_sha256", "outputs_sha256", "result_sha256", "errors"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "receipt_id": {"type": "string", "format": "uuid"},
    "generated_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "result": {"enum": ["passed", "failed"]},
    "contract_set_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "upstream_receipt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "engine_name": {"type": "string", "minLength": 1},
    "engine_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "engine_artifact_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "configuration_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input_events_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "outputs_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "result_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "examples": [
    {"schema_version": "1.0.0", "receipt_id": "dddddddd-dddd-4ddd-8ddd-dddddddddddd", "generated_at": "2026-07-17T12:27:00.000000Z", "result": "passed", "contract_set_sha256": "1111111111111111111111111111111111111111111111111111111111111111", "upstream_receipt_sha256": "2222222222222222222222222222222222222222222222222222222222222222", "engine_name": "openbrec-core-replay", "engine_version": "1.0.0", "engine_artifact_sha256": "3333333333333333333333333333333333333333333333333333333333333333", "configuration_sha256": "4444444444444444444444444444444444444444444444444444444444444444", "input_events_sha256": "5555555555555555555555555555555555555555555555555555555555555555", "outputs_sha256": "6666666666666666666666666666666666666666666666666666666666666666", "result_sha256": "7777777777777777777777777777777777777777777777777777777777777777", "errors": []},
    {"schema_version": "1.0.0", "receipt_id": "dddddddd-dddd-4ddd-8ddd-ddddddddddde", "generated_at": "2026-07-17T12:28:00.000000Z", "result": "failed", "contract_set_sha256": "1111111111111111111111111111111111111111111111111111111111111111", "upstream_receipt_sha256": "2222222222222222222222222222222222222222222222222222222222222222", "engine_name": "openbrec-core-replay", "engine_version": "1.0.0", "engine_artifact_sha256": "3333333333333333333333333333333333333333333333333333333333333333", "configuration_sha256": "4444444444444444444444444444444444444444444444444444444444444444", "input_events_sha256": "8888888888888888888888888888888888888888888888888888888888888888", "outputs_sha256": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855", "result_sha256": "9999999999999999999999999999999999999999999999999999999999999999", "errors": ["invalid input aborted outputs"]}
  ]
}
