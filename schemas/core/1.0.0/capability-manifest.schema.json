{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/core/capability-manifest/1.0.0",
  "title": "CapabilityManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "node_id", "declared_at", "support_level", "capabilities", "capabilities_absent"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "node_id": {"type": "string", "pattern": "^node-[0-9a-f]{8}$"},
    "declared_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "support_level": {"enum": ["supported", "experimental", "unverified", "unavailable"]},
    "capabilities": {"type": "array", "items": {"type": "string", "pattern": "^[a-z][a-z0-9._-]+$"}, "uniqueItems": true},
    "capabilities_absent": {"type": "array", "items": {"type": "string", "pattern": "^[a-z][a-z0-9._-]+$"}, "uniqueItems": true},
    "evidence_refs": {"type": "array", "items": {"type": "string", "pattern": "^urn:sha256:[0-9a-f]{64}$"}, "uniqueItems": true}
  },
  "examples": [
    {"schema_version": "1.0.0", "node_id": "node-a1b2c3d4", "declared_at": "2026-07-17T12:08:00.000000Z", "support_level": "unverified", "capabilities": ["synthetic.observation"], "capabilities_absent": ["hardware"]},
    {"schema_version": "1.0.0", "node_id": "node-a1b2c3d4", "declared_at": "2026-07-17T12:08:01.000000Z", "support_level": "experimental", "capabilities": ["synthetic.observation", "deterministic.replay"], "capabilities_absent": ["ml"], "evidence_refs": ["urn:sha256:5555555555555555555555555555555555555555555555555555555555555555"]}
  ]
}
