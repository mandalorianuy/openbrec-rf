{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/core/audit-event/1.0.0",
  "title": "AuditEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "audit_id", "occurred_at", "actor_type", "actor_id", "action", "object_ref", "result", "policy_ref"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "audit_id": {"type": "string", "format": "uuid"},
    "occurred_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "actor_type": {"enum": ["human", "service", "policy"]},
    "actor_id": {"type": "string", "minLength": 1},
    "action": {"enum": ["read", "write", "seal", "unseal", "extend_retention", "delete", "validate"]},
    "object_ref": {"type": "string", "minLength": 1},
    "result": {"enum": ["allowed", "denied", "failed"]},
    "policy_ref": {"type": "string", "minLength": 1},
    "reason": {"type": "string", "minLength": 1}
  },
  "examples": [
    {"schema_version": "1.0.0", "audit_id": "99999999-9999-4999-8999-999999999999", "occurred_at": "2026-07-17T12:19:00.000000Z", "actor_type": "service", "actor_id": "contract-validator", "action": "validate", "object_ref": "urn:sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa", "result": "allowed", "policy_ref": "urn:openbrec:handling:routine:1.0.0"},
    {"schema_version": "1.0.0", "audit_id": "99999999-9999-4999-8999-999999999998", "occurred_at": "2026-07-17T12:20:00.000000Z", "actor_type": "human", "actor_id": "reviewer-1", "action": "unseal", "object_ref": "urn:sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb", "result": "denied", "policy_ref": "urn:openbrec:handling:life-safety:1.0.0", "reason": "dual authorization missing"}
  ]
}
