{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/core/node-event/1.0.0",
  "title": "NodeEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "node_id", "deployment_id", "action", "occurred_at", "boot_id", "session_id", "reason"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "node_id": {"type": "string", "pattern": "^node-[0-9a-f]{8}$"},
    "deployment_id": {"type": "string", "format": "uuid"},
    "action": {"enum": ["enrolled", "session_started", "degraded", "retired"]},
    "occurred_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "boot_id": {"type": "string", "format": "uuid"},
    "session_id": {"type": "string", "format": "uuid"},
    "reason": {"type": "string", "minLength": 1},
    "missing_capabilities": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  },
  "examples": [
    {"schema_version": "1.0.0", "node_id": "node-a1b2c3d4", "deployment_id": "22222222-2222-4222-8222-222222222222", "action": "enrolled", "occurred_at": "2026-07-17T12:06:00.000000Z", "boot_id": "33333333-3333-4333-8333-333333333333", "session_id": "44444444-4444-4444-8444-444444444444", "reason": "synthetic node"},
    {"schema_version": "1.0.0", "node_id": "node-a1b2c3d4", "deployment_id": "22222222-2222-4222-8222-222222222222", "action": "degraded", "occurred_at": "2026-07-17T12:07:00.000000Z", "boot_id": "33333333-3333-4333-8333-333333333333", "session_id": "44444444-4444-4444-8444-444444444444", "reason": "sensor unavailable", "missing_capabilities": ["acoustic"]}
  ]
}
