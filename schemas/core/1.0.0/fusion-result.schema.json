{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/core/fusion-result/1.0.0",
  "title": "FusionResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "result_id", "engine_name", "engine_version", "configuration_sha256", "state", "supporting_evidence_ids", "contradicting_evidence_ids", "window_start", "window_end", "coverage", "confidence", "conflict_score", "abstained", "abstention_reasons", "capabilities_absent", "valid_until", "limitations", "explanation"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "result_id": {"type": "string", "format": "uuid"},
    "engine_name": {"type": "string", "minLength": 1},
    "engine_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "configuration_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "state": {"enum": ["indicator", "conflicted", "abstained"]},
    "supporting_evidence_ids": {"type": "array", "items": {"type": "string", "format": "uuid"}, "uniqueItems": true},
    "contradicting_evidence_ids": {"type": "array", "items": {"type": "string", "format": "uuid"}, "uniqueItems": true},
    "zone_id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{2,63}$"},
    "window_start": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "window_end": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "coverage": {"type": "string", "minLength": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "conflict_score": {"type": "number", "minimum": 0, "maximum": 1},
    "abstained": {"type": "boolean"},
    "abstention_reasons": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "capabilities_absent": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "valid_until": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "explanation": {"type": "string", "minLength": 1}
  },
  "allOf": [
    {"if": {"properties": {"abstained": {"const": true}}}, "then": {"properties": {"state": {"const": "abstained"}}, "required": ["abstention_reasons"]}},
    {"if": {"properties": {"state": {"const": "indicator"}}}, "then": {"properties": {"abstained": {"const": false}}, "required": ["supporting_evidence_ids"]}}
  ],
  "examples": [
    {"schema_version": "1.0.0", "result_id": "77777777-7777-4777-8777-777777777777", "engine_name": "openbrec-fusion", "engine_version": "1.0.0", "configuration_sha256": "7777777777777777777777777777777777777777777777777777777777777777", "state": "abstained", "supporting_evidence_ids": [], "contradicting_evidence_ids": [], "window_start": "2026-07-17T12:10:00.000000Z", "window_end": "2026-07-17T12:11:02.000000Z", "coverage": "insufficient", "confidence": 0.0, "conflict_score": 0.0, "abstained": true, "abstention_reasons": ["insufficient independent evidence"], "capabilities_absent": ["thermal"], "valid_until": "2026-07-17T12:16:00.000000Z", "limitations": ["synthetic only"], "explanation": "no consolidated claim"},
    {"schema_version": "1.0.0", "result_id": "77777777-7777-4777-8777-777777777778", "engine_name": "openbrec-fusion", "engine_version": "1.0.0", "configuration_sha256": "7777777777777777777777777777777777777777777777777777777777777777", "state": "conflicted", "supporting_evidence_ids": ["66666666-6666-4666-8666-666666666666"], "contradicting_evidence_ids": ["66666666-6666-4666-8666-666666666667"], "zone_id": "zone-a", "window_start": "2026-07-17T12:10:00.000000Z", "window_end": "2026-07-17T12:11:02.000000Z", "coverage": "partial zone", "confidence": 0.3, "conflict_score": 0.8, "abstained": false, "abstention_reasons": [], "capabilities_absent": ["acoustic"], "valid_until": "2026-07-17T12:16:00.000000Z", "limitations": ["conflicting evidence"], "explanation": "requires operator verification"}
  ]
}
