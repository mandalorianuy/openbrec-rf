{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/core/provenance/1.0.0",
  "title": "Provenance",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "name", "version", "artifact_sha256", "recorded_at", "capabilities_present", "capabilities_absent", "limitations"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"enum": ["adapter", "engine", "operator_tool"]},
    "name": {"type": "string", "minLength": 1, "maxLength": 128},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "artifact_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "recorded_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "firmware_version": {"type": "string", "minLength": 1},
    "hardware_model": {"type": "string", "minLength": 1},
    "configuration_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "upstream_receipt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "capabilities_present": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "capabilities_absent": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  },
  "examples": [
    {"schema_version": "1.0.0", "artifact_type": "adapter", "name": "synthetic", "version": "1.0.0", "artifact_sha256": "1111111111111111111111111111111111111111111111111111111111111111", "recorded_at": "2026-07-17T12:00:00.000000Z", "capabilities_present": [], "capabilities_absent": ["hardware"], "limitations": ["synthetic only"]},
    {"schema_version": "1.0.0", "artifact_type": "engine", "name": "openbrec-rules", "version": "1.0.0", "artifact_sha256": "2222222222222222222222222222222222222222222222222222222222222222", "recorded_at": "2026-07-17T12:00:01.000000Z", "configuration_sha256": "3333333333333333333333333333333333333333333333333333333333333333", "capabilities_present": ["deterministic_rules"], "capabilities_absent": ["ml"], "limitations": ["M0 rules"]}
  ]
}
