{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/core/adapter-replay-receipt/1.0.0",
  "title": "AdapterReplayReceipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "receipt_id", "generated_at", "result", "input_sha256", "adapter_name", "adapter_version", "adapter_artifact_sha256", "configuration_sha256", "contract_set_sha256", "normalized_events_sha256", "events_produced", "errors", "handling_policy_ref"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "receipt_id": {"type": "string", "format": "uuid"},
    "generated_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "result": {"enum": ["passed", "failed"]},
    "input_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "adapter_name": {"type": "string", "minLength": 1},
    "adapter_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "adapter_artifact_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "configuration_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "contract_set_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "normalized_events_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "events_produced": {"type": "integer", "minimum": 0},
    "errors": {"type": "array", "items": {"type": "string"}},
    "handling_policy_ref": {"type": "string", "minLength": 1}
  },
  "examples": [
    {"schema_version": "1.0.0", "receipt_id": "cccccccc-cccc-4ccc-8ccc-cccccccccccc", "generated_at": "2026-07-17T12:25:00.000000Z", "result": "passed", "input_sha256": "1111111111111111111111111111111111111111111111111111111111111111", "adapter_name": "synthetic", "adapter_version": "1.0.0", "adapter_artifact_sha256": "2222222222222222222222222222222222222222222222222222222222222222", "configuration_sha256": "3333333333333333333333333333333333333333333333333333333333333333", "contract_set_sha256": "4444444444444444444444444444444444444444444444444444444444444444", "normalized_events_sha256": "5555555555555555555555555555555555555555555555555555555555555555", "events_produced": 1, "errors": [], "handling_policy_ref": "urn:openbrec:handling:routine:1.0.0"},
    {"schema_version": "1.0.0", "receipt_id": "cccccccc-cccc-4ccc-8ccc-cccccccccccd", "generated_at": "2026-07-17T12:26:00.000000Z", "result": "failed", "input_sha256": "6666666666666666666666666666666666666666666666666666666666666666", "adapter_name": "synthetic", "adapter_version": "1.0.0", "adapter_artifact_sha256": "2222222222222222222222222222222222222222222222222222222222222222", "configuration_sha256": "3333333333333333333333333333333333333333333333333333333333333333", "contract_set_sha256": "4444444444444444444444444444444444444444444444444444444444444444", "normalized_events_sha256": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855", "events_produced": 0, "errors": ["invalid input"], "handling_policy_ref": "urn:openbrec:handling:life-safety:1.0.0"}
  ]
}
