{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/core/domain-event/1.0.0",
  "title": "DomainEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "schema_ref", "event_type", "event_id", "idempotency_id", "correlation_id", "causation_event_ids", "incident_id", "origin", "boot_id", "session_id", "sequence", "captured_at", "received_at", "clock_uncertainty_ms", "clock_source", "provenance", "handling_policy", "retention_policy_id", "privacy_flags", "payload"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "schema_ref": {
      "enum": [
        "https://openbrec.org/schemas/core/incident-event/1.0.0",
        "https://openbrec.org/schemas/core/deployment-event/1.0.0",
        "https://openbrec.org/schemas/core/zone-event/1.0.0",
        "https://openbrec.org/schemas/core/node-event/1.0.0",
        "https://openbrec.org/schemas/core/capability-manifest/1.0.0",
        "https://openbrec.org/schemas/core/health-status/1.0.0",
        "https://openbrec.org/schemas/core/observation/1.0.0",
        "https://openbrec.org/schemas/core/evidence/1.0.0",
        "https://openbrec.org/schemas/core/fusion-result/1.0.0",
        "https://openbrec.org/schemas/core/operator-annotation/1.0.0",
        "https://openbrec.org/schemas/core/audit-event/1.0.0",
        "https://openbrec.org/schemas/core/validation-failure/1.0.0",
        "https://openbrec.org/schemas/core/preservation-record/1.0.0"
      ]
    },
    "event_type": {"enum": ["incident_event", "deployment_event", "zone_event", "node_event", "capability_manifest", "health_status", "observation", "evidence", "fusion_result", "operator_annotation", "audit_event", "validation_failure", "preservation_record"]},
    "event_id": {"type": "string", "format": "uuid", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-5[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "idempotency_id": {"type": "string", "pattern": "^urn:sha256:[0-9a-f]{64}$"},
    "correlation_id": {"type": "string", "format": "uuid", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "causation_event_ids": {"type": "array", "items": {"type": "string", "format": "uuid"}, "uniqueItems": true},
    "derivation_key": {"type": "string", "minLength": 1, "maxLength": 512},
    "incident_id": {"type": "string", "format": "uuid"},
    "deployment_id": {"type": "string", "format": "uuid"},
    "zone_id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{2,63}$"},
    "source_node_id": {"type": "string", "pattern": "^node-[0-9a-f]{8}$"},
    "origin": {"enum": ["external", "adapter", "core", "operator"]},
    "source_event_id": {"type": "string", "minLength": 1, "maxLength": 512},
    "boot_id": {"type": "string", "format": "uuid"},
    "session_id": {"type": "string", "format": "uuid"},
    "sequence": {"type": "integer", "minimum": 0, "maximum": 9223372036854775807},
    "captured_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "received_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "clock_uncertainty_ms": {"type": "integer", "minimum": 0},
    "clock_source": {"enum": ["gnss", "ntp", "rtc", "source_reported", "logical", "unknown"]},
    "provenance": {"$ref": "provenance.schema.json"},
    "handling_policy": {"$ref": "handling-policy.schema.json"},
    "retention_policy_id": {"type": "string", "pattern": "^urn:openbrec:retention:[a-z0-9._-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "privacy_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contains_direct_identifier", "contains_raw_payload", "life_safety_relevant"],
      "properties": {
        "contains_direct_identifier": {"type": "boolean"},
        "contains_raw_payload": {"type": "boolean"},
        "life_safety_relevant": {"type": "boolean"}
      }
    },
    "extensions": {"type": "object", "propertyNames": {"format": "uri"}, "additionalProperties": {"type": "object"}},
    "payload": {"type": "object"}
  },
  "allOf": [
    {"if": {"properties": {"event_type": {"const": "incident_event"}, "payload": {"properties": {"action": {"const": "created"}}, "required": ["action"]}}, "required": ["event_type", "payload"]}, "else": {"required": ["deployment_id"]}},
    {"if": {"properties": {"origin": {"enum": ["external", "adapter", "operator"]}}, "required": ["origin"]}, "then": {"required": ["source_event_id"]}},
    {"if": {"properties": {"event_type": {"enum": ["evidence", "fusion_result"]}}, "required": ["event_type"]}, "then": {"properties": {"origin": {"const": "core"}}, "required": ["derivation_key"]}},
    {"if": {"properties": {"event_type": {"const": "incident_event"}}, "required": ["event_type"]}, "then": {"properties": {"schema_ref": {"const": "https://openbrec.org/schemas/core/incident-event/1.0.0"}, "payload": {"$ref": "incident-event.schema.json"}}}},
    {"if": {"properties": {"event_type": {"const": "deployment_event"}}, "required": ["event_type"]}, "then": {"properties": {"schema_ref": {"const": "https://openbrec.org/schemas/core/deployment-event/1.0.0"}, "payload": {"$ref": "deployment-event.schema.json"}}}},
    {"if": {"properties": {"event_type": {"const": "zone_event"}}, "required": ["event_type"]}, "then": {"properties": {"schema_ref": {"const": "https://openbrec.org/schemas/core/zone-event/1.0.0"}, "payload": {"$ref": "zone-event.schema.json"}}}},
    {"if": {"properties": {"event_type": {"const": "node_event"}}, "required": ["event_type"]}, "then": {"properties": {"schema_ref": {"const": "https://openbrec.org/schemas/core/node-event/1.0.0"}, "payload": {"$ref": "node-event.schema.json"}}}},
    {"if": {"properties": {"event_type": {"const": "capability_manifest"}}, "required": ["event_type"]}, "then": {"properties": {"schema_ref": {"const": "https://openbrec.org/schemas/core/capability-manifest/1.0.0"}, "payload": {"$ref": "capability-manifest.schema.json"}}}},
    {"if": {"properties": {"event_type": {"const": "health_status"}}, "required": ["event_type"]}, "then": {"properties": {"schema_ref": {"const": "https://openbrec.org/schemas/core/health-status/1.0.0"}, "payload": {"$ref": "health-status.schema.json"}}}},
    {"if": {"properties": {"event_type": {"const": "observation"}}, "required": ["event_type"]}, "then": {"properties": {"schema_ref": {"const": "https://openbrec.org/schemas/core/observation/1.0.0"}, "payload": {"$ref": "observation.schema.json"}}}},
    {"if": {"properties": {"event_type": {"const": "evidence"}}, "required": ["event_type"]}, "then": {"properties": {"schema_ref": {"const": "https://openbrec.org/schemas/core/evidence/1.0.0"}, "payload": {"$ref": "evidence.schema.json"}}}},
    {"if": {"properties": {"event_type": {"const": "fusion_result"}}, "required": ["event_type"]}, "then": {"properties": {"schema_ref": {"const": "https://openbrec.org/schemas/core/fusion-result/1.0.0"}, "payload": {"$ref": "fusion-result.schema.json"}}}},
    {"if": {"properties": {"event_type": {"const": "operator_annotation"}}, "required": ["event_type"]}, "then": {"properties": {"schema_ref": {"const": "https://openbrec.org/schemas/core/operator-annotation/1.0.0"}, "payload": {"$ref": "operator-annotation.schema.json"}}}},
    {"if": {"properties": {"event_type": {"const": "audit_event"}}, "required": ["event_type"]}, "then": {"properties": {"schema_ref": {"const": "https://openbrec.org/schemas/core/audit-event/1.0.0"}, "payload": {"$ref": "audit-event.schema.json"}}}},
    {"if": {"properties": {"event_type": {"const": "validation_failure"}}, "required": ["event_type"]}, "then": {"properties": {"schema_ref": {"const": "https://openbrec.org/schemas/core/validation-failure/1.0.0"}, "payload": {"$ref": "validation-failure.schema.json"}}}},
    {"if": {"properties": {"event_type": {"const": "preservation_record"}}, "required": ["event_type"]}, "then": {"properties": {"schema_ref": {"const": "https://openbrec.org/schemas/core/preservation-record/1.0.0"}, "payload": {"$ref": "preservation-record.schema.json"}}}}
  ],
  "examples": [
