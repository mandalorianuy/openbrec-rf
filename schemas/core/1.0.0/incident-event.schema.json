{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/core/incident-event/1.0.0",
  "title": "IncidentEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "incident_id", "action", "occurred_at", "handling_policy_ref", "reason"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "incident_id": {"type": "string", "format": "uuid", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "action": {"enum": ["created", "activated", "profile_changed", "closed", "reopened"]},
    "occurred_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "handling_policy_ref": {"type": "string", "pattern": "^urn:openbrec:handling:"},
    "reason": {"type": "string", "minLength": 1, "maxLength": 512},
    "authorized_by": {"type": "string", "minLength": 1}
  },
  "examples": [
    {"schema_version": "1.0.0", "incident_id": "11111111-1111-4111-8111-111111111111", "action": "created", "occurred_at": "2026-07-17T12:00:00.000000Z", "handling_policy_ref": "urn:openbrec:handling:routine:1.0.0", "reason": "synthetic M0 incident"},
    {"schema_version": "1.0.0", "incident_id": "11111111-1111-4111-8111-111111111111", "action": "activated", "occurred_at": "2026-07-17T12:01:00.000000Z", "handling_policy_ref": "urn:openbrec:handling:life-safety:1.0.0", "reason": "exercise activation", "authorized_by": "incident-commander"}
  ]
}
