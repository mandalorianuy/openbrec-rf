{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/core/zone-event/1.0.0",
  "title": "ZoneEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "zone_id", "deployment_id", "action", "geometry_type", "occurred_at", "revision"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "zone_id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{2,63}$"},
    "deployment_id": {"type": "string", "format": "uuid"},
    "action": {"enum": ["defined", "updated", "retired"]},
    "geometry_type": {"enum": ["point", "polygon", "volume"]},
    "occurred_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "revision": {"type": "integer", "minimum": 1},
    "geometry_ref": {"type": "string", "pattern": "^urn:sha256:[0-9a-f]{64}$"}
  },
  "examples": [
    {"schema_version": "1.0.0", "zone_id": "zone-a", "deployment_id": "22222222-2222-4222-8222-222222222222", "action": "defined", "geometry_type": "polygon", "occurred_at": "2026-07-17T12:04:00.000000Z", "revision": 1},
    {"schema_version": "1.0.0", "zone_id": "zone-a", "deployment_id": "22222222-2222-4222-8222-222222222222", "action": "updated", "geometry_type": "volume", "occurred_at": "2026-07-17T12:05:00.000000Z", "revision": 2, "geometry_ref": "urn:sha256:4444444444444444444444444444444444444444444444444444444444444444"}
  ]
}
