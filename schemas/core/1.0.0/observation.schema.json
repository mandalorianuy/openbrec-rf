{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/core/observation/1.0.0",
  "title": "Observation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "observation_id", "sensor_id", "sensor_type", "observation_kind", "window_start", "window_end", "measurements", "quality", "uncertainty", "coverage", "capabilities_absent", "limitations"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "observation_id": {"type": "string", "format": "uuid"},
    "sensor_id": {"type": "string", "minLength": 1},
    "sensor_type": {"enum": ["synthetic", "operator", "addon_registered"]},
    "observation_kind": {"enum": ["measurement", "no_event_detected"]},
    "window_start": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "window_end": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"},
    "zone_id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{2,63}$"},
    "measurements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["measurement_type", "metric", "value", "unit", "uncertainty", "quality", "method"],
        "properties": {
          "measurement_type": {"const": "scalar"},
          "metric": {"type": "string", "pattern": "^[a-z][a-z0-9._-]+$"},
          "value": {"type": "number"},
          "unit": {"type": "string", "minLength": 1, "maxLength": 32},
          "uncertainty": {"type": "number", "minimum": 0},
          "quality": {"type": "number", "minimum": 0, "maximum": 1},
          "method": {"type": "string", "minLength": 1}
        }
      }
    },
    "quality": {"type": "number", "minimum": 0, "maximum": 1},
    "uncertainty": {"type": "number", "minimum": 0, "maximum": 1},
    "coverage": {"type": "string", "minLength": 1},
    "calibration_ref": {"type": "string", "pattern": "^urn:sha256:[0-9a-f]{64}$"},
    "capabilities_absent": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  },
  "examples": [
    {"schema_version": "1.0.0", "observation_id": "55555555-5555-4555-8555-555555555555", "sensor_id": "synthetic-1", "sensor_type": "synthetic", "observation_kind": "measurement", "window_start": "2026-07-17T12:10:00.000000Z", "window_end": "2026-07-17T12:10:01.000000Z", "measurements": [{"measurement_type": "scalar", "metric": "synthetic.level", "value": 0.25, "unit": "1", "uncertainty": 0.1, "quality": 0.8, "method": "fixture"}], "quality": 0.8, "uncertainty": 0.2, "coverage": "synthetic window", "capabilities_absent": ["hardware"], "limitations": ["not field evidence"]},
    {"schema_version": "1.0.0", "observation_id": "55555555-5555-4555-8555-555555555556", "sensor_id": "synthetic-2", "sensor_type": "synthetic", "observation_kind": "no_event_detected", "window_start": "2026-07-17T12:11:00.000000Z", "window_end": "2026-07-17T12:11:02.000000Z", "zone_id": "zone-a", "measurements": [], "quality": 0.5, "uncertainty": 0.5, "coverage": "limited synthetic window", "calibration_ref": "urn:sha256:6666666666666666666666666666666666666666666666666666666666666666", "capabilities_absent": ["thermal", "acoustic"], "limitations": ["no_event_detected is not absence"]}
  ]
}
