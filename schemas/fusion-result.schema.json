{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/fusion-result/1.0.0",
  "title": "OpenBREC Fusion Result",
  "type": "object",
  "required": ["schema_version", "result_id", "incident_id", "timestamp", "status", "confidence", "sources", "limitations"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "result_id": {"type": "string", "format": "uuid"},
    "incident_id": {"type": "string"},
    "timestamp": {"type": "string", "format": "date-time"},
    "zone_id": {"type": ["string", "null"]},
    "void_hypothesis_id": {"type": ["string", "null"]},
    "status": {"enum": ["no_evidence", "weak_indicator", "indicator", "convergent_indicator", "verification_required"]},
    "claim_type": {"enum": ["device_activity", "radio_perturbation", "possible_presence", "movement", "location", "identity_hypothesis"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "estimated_accuracy_m": {"type": ["number", "null"], "minimum": 0},
    "sources": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "supporting_observation_ids": {"type": "array", "items": {"type": "string"}},
    "contradicting_observation_ids": {"type": "array", "items": {"type": "string"}},
    "explanation": {"type": "string"},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "expires_at": {"type": ["string", "null"], "format": "date-time"}
  },
  "additionalProperties": false
}
