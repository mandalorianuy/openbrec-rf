{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/open-spec/human-message-lifecycle-event/1.0.0-draft.1",
  "title": "OpenBREC Human Message Lifecycle Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "event_id", "message_id", "event_type", "occurred_at",
    "actor_type", "actor_id", "actor_role", "verification", "signature",
    "causation_event_ids", "limitations"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0-draft.1"},
    "event_id": {"type": "string", "format": "uuid"},
    "message_id": {"type": "string", "format": "uuid"},
    "event_type": {
      "enum": [
        "sos.created", "sos.queued", "transport.transmitted",
        "transport.relay_observed", "gateway.received", "operator.seen",
        "operator.accepted", "sos.cancel_requested", "sos.expired", "sos.failed"
      ]
    },
    "occurred_at": {"type": "string", "format": "date-time"},
    "actor_type": {"enum": ["terminal", "adapter", "gateway", "operator", "policy"]},
    "actor_id": {"type": "string", "minLength": 1, "maxLength": 96},
    "actor_role": {"type": "string", "minLength": 1, "maxLength": 64},
    "verification": {"enum": ["verified", "unverified"]},
    "signature": {"type": "string", "pattern": "^[A-Za-z0-9_-]{86}$"},
    "causation_event_ids": {
      "type": "array", "uniqueItems": true,
      "items": {"type": "string", "format": "uuid"}
    },
    "reason": {"type": "string", "minLength": 1, "maxLength": 240},
    "limitations": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"event_type": {"enum": ["operator.accepted", "sos.cancel_requested", "sos.expired", "sos.failed"]}}, "required": ["event_type"]},
      "then": {"required": ["reason"]}
    }
  ]
}
