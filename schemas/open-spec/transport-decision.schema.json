{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbrec.org/schemas/open-spec/transport-decision/1.0.0-draft.1",
  "title": "OpenBREC Transport Selection Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "decision_id", "mission_profile", "selected_bearer",
    "planes", "evidence_level", "regulatory_mode", "selection_rationale",
    "rejected_alternatives", "application_invariants", "known_gaps"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0-draft.1"},
    "decision_id": {"type": "string", "pattern": "^transport-decision-[a-z0-9-]{3,48}$"},
    "mission_profile": {"type": "string", "minLength": 3, "maxLength": 160},
    "selected_bearer": {"enum": ["lorawan_private", "meshtastic", "meshcore", "reticulum_rnode", "carry_bundle"]},
    "planes": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"enum": ["human", "machine", "federation", "artifact_transfer"]}
    },
    "evidence_level": {"enum": ["unverified", "specified", "simulated", "lab_validated", "field_validated"]},
    "regulatory_mode": {"enum": ["receive_only", "conducted_only", "jurisdiction_validated", "emergency_assumed_risk"]},
    "selection_rationale": {
      "type": "object", "additionalProperties": false,
      "required": ["mission", "mobility", "topology", "density", "payload_and_latency", "energy", "privacy_and_security", "regulation", "available_hardware", "rf_coexistence"],
      "properties": {
        "mission": {"type": "string", "minLength": 1},
        "mobility": {"type": "string", "minLength": 1},
        "topology": {"type": "string", "minLength": 1},
        "density": {"type": "string", "minLength": 1},
        "payload_and_latency": {"type": "string", "minLength": 1},
        "energy": {"type": "string", "minLength": 1},
        "privacy_and_security": {"type": "string", "minLength": 1},
        "regulation": {"type": "string", "minLength": 1},
        "available_hardware": {"type": "string", "minLength": 1},
        "rf_coexistence": {"type": "string", "minLength": 1}
      }
    },
    "rejected_alternatives": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["bearer", "reason", "reconsider_when"],
        "properties": {
          "bearer": {"enum": ["lorawan_private", "meshtastic", "meshcore", "reticulum_rnode", "carry_bundle", "other_extension"]},
          "reason": {"type": "string", "minLength": 1},
          "reconsider_when": {"type": "string", "minLength": 1}
        }
      }
    },
    "application_invariants": {
      "type": "object", "additionalProperties": false,
      "required": ["signed_envelope", "stable_message_id", "ttl", "deduplication", "anti_loop", "priority_before_bearer", "per_path_receipts", "raw_bridge_forbidden", "transport_ack_not_semantic_acceptance"],
      "properties": {
        "signed_envelope": {"const": true},
        "stable_message_id": {"const": true},
        "ttl": {"const": true},
        "deduplication": {"const": true},
        "anti_loop": {"const": true},
        "priority_before_bearer": {"const": true},
        "per_path_receipts": {"const": true},
        "raw_bridge_forbidden": {"const": true},
        "transport_ack_not_semantic_acceptance": {"const": true}
      }
    },
    "assumed_risk_decision": {
      "type": "object", "additionalProperties": false,
      "required": ["jurisdiction", "frequency_or_band", "tx_power_and_eirp", "antenna", "airtime_budget", "geography", "responsible_actor", "reason", "starts_at", "expires_at", "monitoring", "stop_condition", "kill_switch", "dual_authorization"],
      "properties": {
        "jurisdiction": {"type": "string", "minLength": 2},
        "frequency_or_band": {"type": "string", "minLength": 1},
        "tx_power_and_eirp": {"type": "string", "minLength": 1},
        "antenna": {"type": "string", "minLength": 1},
        "airtime_budget": {"type": "string", "minLength": 1},
        "geography": {"type": "string", "minLength": 1},
        "responsible_actor": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "starts_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string", "format": "date-time"},
        "monitoring": {"type": "string", "minLength": 1},
        "stop_condition": {"type": "string", "minLength": 1},
        "kill_switch": {"type": "string", "minLength": 1},
        "dual_authorization": {
          "type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "implementation_id": {"type": "string", "minLength": 1},
    "physical_evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["evidence_pack_sha256", "configuration_sha256", "tested_at"],
      "properties": {
        "evidence_pack_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "configuration_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "tested_at": {"type": "string", "format": "date-time"}
      }
    },
    "known_gaps": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  },
  "allOf": [
    {
      "if": {"properties": {"regulatory_mode": {"const": "emergency_assumed_risk"}}, "required": ["regulatory_mode"]},
      "then": {"required": ["assumed_risk_decision"]},
      "else": {"not": {"required": ["assumed_risk_decision"]}}
    },
    {
      "if": {"properties": {"evidence_level": {"enum": ["lab_validated", "field_validated"]}}, "required": ["evidence_level"]},
      "then": {"required": ["implementation_id", "physical_evidence"]}
    }
  ]
}
